# Supabase (required for assessment submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SendGrid (required for sending user + admin emails on submission)
SENDGRID_API_KEY=

# Optional
# ANTHROPIC_API_KEY=

# Admin dashboard: set to your chosen password (e.g. in .env.local)
# ADMIN_PASSWORD=
# NEXT_PUBLIC_BOOKING_URL=
# BOOKING_URL=
